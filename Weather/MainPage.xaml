<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Weather.MainPage"
             Shell.NavBarIsVisible="False">
    
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2C3E50" Offset="0.0" />
            <GradientStop Color="#000000" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto, Auto, Auto, *" Padding="20" RowSpacing="20">

        <Border Grid.Row="0" 
                Background="#30FFFFFF" 
                StrokeShape="RoundRectangle 15" 
                HorizontalOptions="Center" 
                Margin="0,10,0,0" 
                Padding="15,5">
            <DatePicker x:Name="MyDatePicker"
                        Format="dd MMMM yyyy"
                        TextColor="White"
                        FontAttributes="Bold"
                        DateSelected="OnDateSelected" />
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="1.5*, *,1.5*" ColumnSpacing="10" VerticalOptions="Center" >

            <Border Grid.Column="0" 
                    
                    Background="#50FFFFFF" 
                    StrokeShape="RoundRectangle 20" 
                    Padding="10,0"
                    HeightRequest="100"
                    HorizontalOptions="Fill">
                <Picker x:Name="CityPicker" 
                        Title="Şehir Seçin"
                        TitleColor="White"
                        TextColor="White" 
                        FontSize="15"
                        VerticalOptions="Center"
                        HorizontalOptions="Fill"
                        SelectedIndexChanged="OnCitySelected"
                        ItemDisplayBinding="{Binding .}" />
            </Border>

            <Image  x:Name="WeatherIconImage"
                    Grid.Column="1"
                    Source="sun" 
                    WidthRequest="110"
                    HeightRequest="110"
                    Aspect="AspectFit"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />

            <Border Grid.Column="2" Background="#50FFFFFF" StrokeShape="RoundRectangle 18" Padding="10" HeightRequest="100">
                <Label x:Name="TempLabel"
                       Text="--°C" 
                       FontAttributes="Bold" 
                       FontSize="22"
                       TextColor="White"
                       HorizontalOptions="Center" 
                       VerticalOptions="Center"/>
            </Border>
        </Grid>

        <ScrollView Grid.Row="2" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout x:Name="HourlyForecastList" Spacing="15" Padding="5,10" />
        </ScrollView>

        <Border Grid.Row="3" 
                StrokeShape="RoundRectangle 35" 
                Margin="0,10,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#B0FFFFFF" Offset="0" />
                    <GradientStop Color="#70FFFFFF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="15" Opacity="0.05" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto, *" Padding="25">
                <HorizontalStackLayout Grid.Row="0" Spacing="12" Margin="0,0,0,15">
                    <Label Text="💡" FontSize="40" VerticalOptions="Center"/>
                    <Label Text="GÜNÜN TAVSİYESİ" FontSize="30" FontAttributes="Bold" TextColor="#455A64" CharacterSpacing="1.5" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label x:Name="SuggestionLabel" Grid.Row="1" TextColor="#37474F" FontSize="25" LineHeight="1.4" VerticalOptions="Start"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>